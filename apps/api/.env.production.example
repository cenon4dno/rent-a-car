# Production environment — copy to .env on the Azure App Service instance
# Configure these via Application Settings in the Azure portal (never commit real values)

DATABASE_URL="postgresql://user:password@host:5432/rentacar?schema=public"
JWT_SECRET="<strong-random-64-char-secret>"
PORT=4000
ALLOWED_ORIGINS="https://your-domain.com"

# PayMongo (get from dashboard.paymongo.com)
PAYMONGO_SECRET_KEY="sk_live_..."
PAYMONGO_WEBHOOK_SECRET="<paymongo-webhook-secret>"

