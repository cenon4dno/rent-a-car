# Production environment — configure via Azure App Service Application Settings

NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="<strong-random-64-char-secret>"
NEXT_PUBLIC_API_URL="https://your-domain.com/api/v1"

# Google OAuth (console.cloud.google.com)
AUTH_GOOGLE_ID="<google-client-id>"
AUTH_GOOGLE_SECRET="<google-client-secret>"

# Microsoft Entra ID (portal.azure.com → App Registrations)
AUTH_MICROSOFT_ENTRA_ID_ID="<azure-app-client-id>"
AUTH_MICROSOFT_ENTRA_ID_SECRET="<azure-app-client-secret>"
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/<tenant-id>/v2.0"

# Apple OAuth (developer.apple.com → Certificates, Identifiers & Profiles)
# AUTH_APPLE_ID="<apple-service-id>"
# AUTH_APPLE_SECRET="<apple-private-key>"
